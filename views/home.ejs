<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head") %>
    <title>Home</title>
    <!-- Inline style fix for uniform images and cards -->
    <style>
      .card-img-fixed {
        height: 200px; /* Adjust this height to your liking */
        object-fit: contain;
      }
      .equal-height-card {
        height: 100%;
      }
    </style>
  </head>
  <body>
    <%- include("partials/nav") %>

    <!-- Added g-4 for grid spacing and h-100 to make cards equal height -->
    <div class="container mt-3 row row-cols-1 row-cols-md-4 g-4">
      <% blogs.forEach(blog => { %>
        <div class="col">
          <!-- Removed "col" class from card, removed hardcoded width, added equal-height-card -->
          <div class="card equal-height-card">
            <!-- Added card-img-fixed class -->
            <img src="<%= blog.coverImageUrl %>" class="card-img-top card-img-fixed" alt="Cover Image">
            <div class="card-body d-flex flex-column justify-content-between">
              <!-- Fixed EJS tag: Added '=' to actually display the title -->
              <h5 class="card-title"><%= blog.title %></h5>
              <a href="/blog/<%= blog._id %>" class="btn btn-primary w-100">View</a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
    
    <%- include("partials/scripts") %>
  </body>
</html>
