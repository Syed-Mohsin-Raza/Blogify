<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head") %>
    <title>Blog</title>
  </head>
  <body>
    <%- include("partials/nav") %>

    <div class="container mt-4">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverImageUrl %>" alt="Blog Cover Image" width="600px">
        <pre class="mt-3"><%= blog.body %></pre>
    </div>

    <div class="container mt-4">
      <img src="<%= blog.createdBy.profileImage %>" alt="Profile Image" width="50px">
      <%= blog.createdBy.fullName %>
    </div>  

    <%- include("./partials/scripts") %>
  </body>
  </html>
